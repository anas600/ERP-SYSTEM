{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Database=erp_system;Username=erp_user;Password=erp_password",
    "Redis": "localhost:6379"
  },
  "Marten": {
    "ConnectionString": "Host=localhost;Database=erp_events;Username=erp_user;Password=erp_password",
    "SchemaName": "mt_events"
  },
  "JwtSettings": {
    "Secret": "REPLACE_WITH_SECURE_SECRET_AT_LEAST_32_CHARS_LONG_DEV_ONLY",
    "Issuer": "ERP-SYSTEM",
    "Audience": "ERP-SYSTEM-Users",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 14
  },
  "Database": {
    "AutoMigrate": true
  }
}
